{
  "name": "verifiable-intelligence-demo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build:wasm": "wasm-pack build verifier/wasm --target web --release --out-dir pkg --out-name vi_commitllm_verifier && rm -f verifier/wasm/pkg/.gitignore",
    "test:demo": "playwright test",
    "test:wasm": "playwright test tests/commitllm-wasm.spec.js",
    "test:docs": "node scripts/test-doc-boundaries.js",
    "test:release": "node scripts/test-release-comprehension.js",
    "test:pin": "node scripts/ci/check-commitllm-pin.js",
    "test:provider": "node scripts/test-provider-entrypoint.js",
    "test:changelog-pin": "node scripts/ci/check-changelog-pin.js --self-test && node scripts/ci/check-changelog-pin.js",
    "test:commitllm-rename-watch": "node scripts/ci/watch-commitllm-rename.js --self-test",
    "test:secret-scan": "node scripts/ci/secret-scan.js --self-test && node scripts/ci/secret-scan.js",
    "test:size-budget": "node scripts/ci/check-size-budgets.js",
    "test:workflows": "scripts/ci/test-actionlint.sh",
    "test:error-envelopes": "node scripts/validate-error-envelopes.js",
    "bench:browser": "node scripts/ci/collect-browser-perf.js",
    "test:schema": "node scripts/validate-schema-fixtures.js --self-test && node scripts/validate-schema-fixtures.js",
    "test:tamper": "node scripts/test-viex-tamper-suite.js",
    "test:broker": "node scripts/test-broker-api.js",
    "test:bundle": "npm run test:schema && npm run test:tamper && npm run test:broker && npm run test:provider && npm run test:docs && npm run test:release && npm run test:pin && npm run test:changelog-pin && npm run test:commitllm-rename-watch"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "ajv": "^8.17.1"
  }
}
